#include <iostream>
#include <cstdlib>
#include <unistd.h>
#include <sys/wait.h>
#include <vector>

// Función para preparar el entorno de Python antes de ejecutar
void prepare_python_env() {
    // Evita la creación de archivos .pyc que pueden causar errores de permisos en PRoot
    setenv("PYTHONDONTWRITEBYTECODE", "1", 1);
    // Asegura que el output sea fluido y no se quede en buffer
    setenv("PYTHONUNBUFFERED", "1", 1);
    // Define el path temporal para compilaciones (ajusta a tu ruta de Kali)
    setenv("TMPDIR", "/tmp", 1);
    
    std::cout << "⚙️ Entorno de Python optimizado para PRoot." << std::endl;
}

int main(int argc, char* argv[]) {
    if (argc < 2) {
        std::cout << "Uso: ./kernel_wrapper <comando_python>" << std::endl;
        return 1;
    }

    prepare_python_env();

    // Simulación de gestión de subprocesos (lo que haría un kernel scheduler)
    pid_t pid = fork();

    if (pid == 0) {
        // Proceso hijo: Ejecuta el flujo de Python
        execvp(argv[1], &argv[1]);
        // Si execvp falla:
        perror("❌ Error al ejecutar el comando");
        exit(1);
    } else if (pid > 0) {
        // Proceso padre: Monitor de salud del proceso
        int status;
        waitpid(pid, &status, 0);
        if (WIFEXITED(status)) {
            std::cout << "\n✅ Workflow finalizado con código: " << WEXITSTATUS(status) << std::endl;
        }
    } else {
        perror("❌ Error en fork");
        return 1;
    }

    return 0;
}
