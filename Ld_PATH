#include <iostream>
#include <vector>
#include <string>
#include <filesystem>
#include <unistd.h>

class NetHunterPlatform {
public:
    // Directorios donde suelen vivir los binarios de NetHunter/Kali
    std::vector<std::string> critical_paths = {
        "/data/local/nhsystem/kali-arm64/usr/bin",
        "/data/local/nhsystem/kali-arm64/bin",
        "/data/local/nhsystem/kali-arm64/usr/local/bin",
        "/data/data/com.termux/files/usr/bin"
    };

    void fix_environment() {
        std::cout << "🛠️  Sincronizando plataforma NetHunter..." << std::endl;
        
        std::string new_path = getenv("PATH");
        for (const auto& path : critical_paths) {
            // Verificamos si el directorio existe antes de añadirlo
            if (std::filesystem::exists(path)) {
                new_path = path + ":" + new_path;
            }
        }
        
        // Inyectamos el nuevo PATH al proceso actual y sus hijos
        setenv("PATH", new_path.c_str(), 1);
        
        // Solución al error de librerías compartidas (.so not found)
        setenv("LD_LIBRARY_PATH", "/data/local/nhsystem/kali-arm64/usr/lib:/data/local/nhsystem/kali-arm64/lib", 1);
        
        std::cout << "✅ PATH y Librerías actualizadas. Errores de 'command not found' mitigados." << std::endl;
    }

    void run_secure_command(std::string cmd) {
        std::cout << "🚀 Ejecutando en entorno protegido: " << cmd << std::endl;
        // Forzamos la ejecución a través de la capa de compatibilidad
        std::string full_cmd = "bootkali " + cmd; 
        system(full_cmd.c_str());
    }
};

int main(int argc, char* argv[]) {
    NetHunterPlatform platform;
    platform.fix_environment();

    if (argc > 1) {
        std::string command;
        for (int i = 1; i < argc; ++i) command += std::string(argv[i]) + " ";
        platform.run_secure_command(command);
    } else {
        std::cout << "💡 Uso: ./nh_platform <comando_nethunter>" << std::endl;
    }

    return 0;
}
