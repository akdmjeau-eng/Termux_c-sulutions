#include <iostream>
#include <string>
#include <vector>
#include <thread>
#include <chrono>

class PersistenceEngine {
public:
    // Mantiene la VM y el VNC vivos pase lo que pase
    void monitor_vm_health() {
        while (true) {
            // Verificamos si el proceso de la VM o VNC sigue corriendo
            if (!is_process_running("qemu-system") || !is_process_running("vncserver")) {
                std::cout << "⚠️ Fallo detectado en la persistencia. Reiniciando servicios..." << std::endl;
                restart_services();
            }
            std::this_thread::sleep_for(std::chrono::seconds(30));
        }
    }

    // Lógica de autoconectividad basada en prioridad
    void manage_autoconnect() {
        std::vector<std::string> priority_ssids = {"Mi_Auto_OBD2", "Casa_Smart_5G", "Oficina_Secure"};
        
        while (true) {
            std::cout << "🔍 Escaneando entorno para autoconectividad..." << std::endl;
            for (const auto& ssid : priority_ssids) {
                if (can_see_network(ssid)) {
                    std::cout << "🔗 Red prioritaria encontrada: " << ssid << ". Conectando..." << std::endl;
                    connect_to_wifi(ssid);
                    break; 
                }
            }
            std::this_thread::sleep_for(std::chrono::minutes(2));
        }
    }

private:
    bool is_process_running(std::string name) {
        // Ejecuta 'pgrep' para verificar si el proceso existe
        std::string cmd = "pgrep " + name + " > /dev/null";
        return (system(cmd.c_str()) == 0);
    }

    void restart_services() {
        system("vncserver :1");
        // Aquí relanzarías tu script de Arch Linux Rootless
    }

    bool can_see_network(std::string ssid) {
        // Usa termux-wifi-scaninfo para detectar redes cercanas
        return (system(("termux-wifi-scaninfo | grep " + ssid + " > /dev/null").c_str()) == 0);
    }

    void connect_to_wifi(std::string ssid) {
        system(("termux-wifi-connection -s " + ssid).c_str());
    }
};

int main() {
    PersistenceEngine engine;

    // Hilos independientes para que el monitoreo sea constante
    std::thread health_thread(&PersistenceEngine::monitor_vm_health, &engine);
    std::thread connect_thread(&PersistenceEngine::manage_autoconnect, &engine);

    std::cout << "🛡️ Persistence Guard activo. 📡 Motor de autoconectividad en línea." << std::endl;

    health_thread.join();
    connect_thread.join();

    return 0;
}
