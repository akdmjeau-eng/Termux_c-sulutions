#include <iostream>
#include <string>
#include <vector>

class KaliImageSupport {
public:
    // Monta una imagen ISO/IMG de Kali en modo lectura para forense
    void mount_kali_image(std::string image_path, std::string mount_point) {
        std::cout << "📂 Preparando montaje de imagen: " << image_path << std::endl;
        
        // En proot/rootless, usamos un montaje simulado mediante -b (bind)
        // Si tienes una imagen extraída, la vinculamos al sistema de Arch
        std::string cmd = "mkdir -p " + mount_point + " && proot -b " + image_path + ":" + mount_point;
        
        if (system(cmd.c_str()) == 0) {
            std::cout << "✅ Imagen vinculada en " << mount_point << std::endl;
        }
    }

    // Soporte para particiones de persistencia (ext4)
    void enable_persistence_layer(std::string persistence_img) {
        std::cout << "💾 Activando capa de persistencia: " << persistence_img << std::endl;
        // Vincula el archivo de persistencia para que Arch pueda escribir en él
        system(("proot -b " + persistence_img + ":/mnt/persistence").c_str());
    }

    // Análisis rápido de la estructura de la imagen (tipo de partición)
    void analyze_usb_structure(std::string device) {
        std::cout << "🔍 Analizando tabla de particiones de " << device << "..." << std::endl;
        system(("fdisk -l " + device).c_str());
    }
};

int main() {
    KaliImageSupport kali;

    // Supongamos que tienes un dump de tu USB de Kali
    kali.analyze_usb_structure("kali_live.img");
    kali.mount_kali_image("kali_live.img", "/mnt/kali_usb");
    
    std::cout << "\n🛡️ Soporte Forense Activo. Puedes explorar los archivos en /mnt/kali_usb" << std::endl;

    return 0;
}
