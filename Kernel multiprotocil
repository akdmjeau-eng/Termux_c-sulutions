#include <iostream>
#include <vector>
#include <string>
#include <queue>
#include <mutex>
#include <condition_variable>

// Tipos de señales que el sistema puede procesar
enum class SignalType { CAR_PROXIMITY, WIFI_SSID_FOUND, SMART_HOME_EVENT };

struct SystemEvent {
    SignalType type;
    std::string payload;
};

class UniversalKernel {
private:
    std::queue<SystemEvent> eventQueue;
    std::mutex mtx;
    std::condition_variable cv;
    bool running = true;

public:
    // Hilo que procesa los eventos en segundo plano (Worker)
    void process_events() {
        while (running) {
            std::unique_lock<std::mutex> lock(mtx);
            cv.wait(lock, [this] { return !eventQueue.empty() || !running; });

            if (!running) break;

            SystemEvent event = eventQueue.front();
            eventQueue.pop();
            lock.unlock();

            handle_dispatch(event);
        }
    }

    void push_event(SystemEvent e) {
        {
            std::lock_guard<std::mutex> lock(mtx);
            eventQueue.push(e);
        }
        cv.notify_one();
    }

    void handle_dispatch(SystemEvent e) {
        if (e.type == SignalType::CAR_PROXIMITY) {
            std::cout << "🚀 [KERNEL] Auto cerca. Activando protocolo 'Llegada a Casa'..." << std::endl;
            // Aquí llamarías a los módulos de luces y refri
        } else if (e.type == SignalType::WIFI_SSID_FOUND) {
            std::cout << "🌐 [KERNEL] Red WiFi detectada: " << e.payload << ". Ajustando seguridad." << std::endl;
        }
    }

    void stop() {
        running = false;
        cv.notify_all();
    }
};
