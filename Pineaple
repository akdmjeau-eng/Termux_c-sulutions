#include <iostream>
#include <string>
#include <vector>

class PineappleSupport {
public:
    // Configura el ruteo para que la piña tenga internet a través de tu Android
    void setup_pineapple_network(std::string interface) {
        std::cout << "🍍 Detectando Piña WiFi en interfaz: " << interface << "..." << std::endl;
        
        // Comandos de IP Forwarding (Requiere el Root Engine que creamos)
        system("sysctl -w net.ipv4.ip_forward=1");
        system(("iptables -t nat -A POSTROUTING -o wlan0 -j MASQUERADE").c_str());
        system(("iptables -A FORWARD -i " + interface + " -o wlan0 -m state --state RELATED,ESTABLISHED -j ACCEPT").c_str());
        system(("iptables -A FORWARD -i wlan0 -o " + interface + " -j ACCEPT").c_str());
        
        std::cout << "✅ Compartición de internet activa para la Piña." << std::endl;
    }

    // Crea un túnel para acceder al panel 172.16.42.1:1471 desde tu VS Code o navegador
    void bridge_dashboard() {
        std::cout << "🔗 Puenteando Dashboard de la Piña a localhost:1471..." << std::endl;
        // Usamos el Port-Forwarding Engine para exponer el panel
        system("ssh -N -L 1471:172.16.42.1:1471 root@172.16.42.1 &");
    }

    // Monitorea si la piña se desconecta (Persistence Guard)
    void monitor_pine_connection(std::string iface) {
        std::string cmd = "ip addr show " + iface + " | grep 'state UP' > /dev/null";
        if (system(cmd.c_str()) != 0) {
            std::cerr << "⚠️ Piña desconectada. Reintentando handoff..." << std::endl;
        }
    }
};

int main() {
    PineappleSupport pine;
    
    // 1. Iniciamos el soporte de red
    pine.setup_pineapple_network("usb0");
    
    // 2. Puenteamos el panel de control
    pine.bridge_dashboard();
    
    std::cout << "\n🌟 Soporte para WiFi Pineapple Activo." << std::endl;
    std::cout << "Accede al panel en: http://localhost:1471" << std::endl;

    return 0;
}
