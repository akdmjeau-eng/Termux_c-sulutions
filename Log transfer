#include <iostream>
#include <sys/socket.h>
#include <netinet/in.h>
#include <arpa/inet.h>
#include <unistd.h>
#include <thread>
#include <cstring> // Para strerror

// Función mejorada con logs de transferencia
void forward_traffic(int src, int dest, std::string direction) {
    char buffer[8192]; // Buffer más grande para mejor rendimiento
    ssize_t bytes;
    while ((bytes = recv(src, buffer, sizeof(buffer), 0)) > 0) {
        if (send(dest, buffer, bytes, 0) < 0) break;
        // Opcional: imprimir actividad (útil en entornos de testing)
        // std::cout << "[" << direction << "] " << bytes << " bytes transferidos." << std::endl;
    }
    shutdown(src, SHUT_RDWR);
    shutdown(dest, SHUT_RDWR);
    close(src);
    close(dest);
}

int main() {
    int server_fd, client_fd, remote_fd;
    struct sockaddr_in address, remote_addr;
    int opt = 1;

    server_fd = socket(AF_INET, SOCK_STREAM, 0);

    // MEJORA 1: Permitir reutilizar el puerto inmediatamente tras cerrar el programa
    setsockopt(server_fd, SOL_SOCKET, SO_REUSEADDR | SO_REUSEPORT, &opt, sizeof(opt));

    address.sin_family = AF_INET;
    address.sin_addr.s_addr = INADDR_ANY;
    address.sin_port = htons(8888); 

    if (bind(server_fd, (struct sockaddr *)&address, sizeof(address)) < 0) {
        std::cerr << "❌ Error en bind: " << strerror(errno) << std::endl;
        return 1;
    }

    listen(server_fd, 5);
    std::cout << "🛡️ Túnel de Seguridad Activo [Puerto 8888 -> SSH 2222]" << std::endl;

    while (true) {
        client_fd = accept(server_fd, NULL, NULL);
        std::cout << "🔌 Conexión entrante detectada..." << std::endl;

        remote_fd = socket(AF_INET, SOCK_STREAM, 0);
        remote_addr.sin_family = AF_INET;
        remote_addr.sin_port = htons(2222); // El puerto de tu segundo Kali
        inet_pton(AF_INET, "127.0.0.1", &remote_addr.sin_addr);

        if (connect(remote_fd, (struct sockaddr *)&remote_addr, sizeof(remote_addr)) == 0) {
            std::cout << "✅ Puente establecido con éxito." << std::endl;
            // MEJORA 2: Tráfico bidireccional asíncrono
            std::thread(forward_traffic, client_fd, remote_fd, "A->B").detach();
            std::thread(forward_traffic, remote_fd, client_fd, "B->A").detach();
        } else {
            std::cerr << "⚠️ No se pudo conectar al Kali de destino." << std::endl;
            close(client_fd);
        }
    }
    return 0;
}
