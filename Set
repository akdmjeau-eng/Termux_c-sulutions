#include <iostream>
#include <string>
#include <cstdlib>

class SETSupport {
public:
    // Configura las variables necesarias para que SET no falle en Arch Rootless
    void prepare_set_environment() {
        std::cout << "🛠️ Optimizando Arch para Social-Engineer Toolkit..." << std::endl;
        setenv("PYTHONPATH", "/usr/share/set/", 1);
        // Evita que SET intente actualizarse de forma agresiva en entornos Proot
        system("sed -i 's/UPDATE_SELF=ON/UPDATE_SELF=OFF/g' /etc/setoolkit/set.config");
    }

    // Crea un túnel para que el ataque sea accesible desde fuera de tu WiFi
    void start_network_tunnel(int port) {
        std::cout << "🌐 Abriendo túnel para el puerto " << port << "..." << std::endl;
        // Lanzamos un túnel SSH reverso (Rootless compatible)
        std::string tunnel_cmd = "ssh -R 80:localhost:" + std::to_string(port) + " nokey@localhost.run &";
        system(tunnel_cmd.c_str());
    }

    // Lanza SET directamente en el entorno de Arch
    void launch_set() {
        std::cout << "🚀 Iniciando SET..." << std::endl;
        system("proot -0 -r ~/arch -b /dev -b /proc setoolkit");
    }
};

int main() {
    SETSupport set_helper;

    set_helper.prepare_set_environment();
    set_helper.start_network_tunnel(80); // Abrir puerto para Vector de Phishing
    set_helper.launch_set();

    return 0;
}
